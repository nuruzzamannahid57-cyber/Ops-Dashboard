# Turso Database (same DB as the escalation form)
TURSO_DATABASE_URL=libsql://your-database-name.aws-ap-south-1.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Google OAuth (from Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Session signing secret — generate with: openssl rand -base64 32
JWT_SECRET=your_random_secret_here

# Server
PORT=3000
